# ============================================================
# SentinelOps — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ──────────────── Server (Node.js / Express) ─────────────────
PORT=4000
NODE_ENV=development
SYNC_LOCAL_TOKEN=B95A65D694E517197FB414394E205D6669C7CCB60937978D8031D71AC4127EB5
VITE_API_BASE_URL=http://localhost:4000

# MongoDB — use localhost if running MongoDB Compass locally
MONGO_URI=mongodb://localhost:27017/sentinelops

# JWT Secrets — generate strong random strings (min 32 chars)
JWT_SECRET=9ae1fca0ab6905b99a4d826795f2e0c123134ba0c3811c0649e795b5a196df79
JWT_REFRESH_SECRET=53a9cde509a02a444ac979ec11c86e7e325273925599420f230a237fce963556

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# ML microservice URL
ML_SERVICE_URL=http://localhost:8000

# Upload config
MAX_UPLOAD_SIZE_GB=3
# Legacy fallback if you prefer megabytes instead
# MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads

# ──────────────── ML Service (Python / FastAPI) ──────────────
ML_PORT=8000
MODEL_SAVE_PATH=./data/saved_models
ML_MONGO_URI=mongodb://localhost:27017/sentinelops
