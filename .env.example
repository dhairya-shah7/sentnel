# SentinelOps - Environment Variables
# Copy this file to .env and fill in your values.

# Server (Node.js / Express)
PORT=4000
NODE_ENV=development

# MongoDB - use localhost if running MongoDB Compass locally
MONGO_URI=mongodb://localhost:27017/sentinelops

# JWT Secrets - generate strong random strings (min 32 chars)
JWT_SECRET=CHANGE_ME_sentinelops_jwt_secret_at_least_32_characters
JWT_REFRESH_SECRET=CHANGE_ME_sentinelops_refresh_secret_at_least_32_chars

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173
# Optional extra origins, comma-separated
# CLIENT_URLS=http://localhost:5173,http://localhost:5174
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.8:5173

# ML microservice URL
ML_SERVICE_URL=http://localhost:8000

# Optional deployment modes
OFFLINE_MODE=true
NO_CLOUD_MODE=true
VITE_API_BASE_URL=http://localhost:4000
SYNC_LOCAL_TOKEN=B95A65D694E517197FB414394E205D6669C7CCB60937978D8031D71AC4127EB5

# Upload config
MAX_UPLOAD_SIZE_GB=1
# Legacy fallback if you prefer megabytes instead
# MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads

# ML Service (Python / FastAPI)
ML_PORT=8000
MODEL_SAVE_PATH=./data/saved_models
ML_MONGO_URI=mongodb://localhost:27017/sentinelops
