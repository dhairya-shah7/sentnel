{
  "name": "sentinelops-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "SentinelOps desktop installer shell",
  "main": "desktop/main.cjs",
  "scripts": {
    "build:client": "npm --prefix client run build",
    "desktop:dist": "npm run build:client && electron-builder"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sentinelops.desktop",
    "productName": "SentinelOps",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "client/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
