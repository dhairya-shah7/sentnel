# ============================================================
# SentinelOps — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ──────────────── Server (Node.js / Express) ─────────────────
PORT=4000
NODE_ENV=development

# MongoDB — use localhost if running MongoDB Compass locally
MONGO_URI=mongodb://localhost:27017/sentinelops

# JWT Secrets — generate strong random strings (min 32 chars)
JWT_SECRET=CHANGE_ME_sentinelops_jwt_secret_at_least_32_characters
JWT_REFRESH_SECRET=CHANGE_ME_sentinelops_refresh_secret_at_least_32_chars

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# ML microservice URL
ML_SERVICE_URL=http://localhost:8000

# Upload config
MAX_UPLOAD_SIZE_MB=2000
UPLOAD_DIR=./uploads

# ──────────────── ML Service (Python / FastAPI) ──────────────
ML_PORT=8000
MODEL_SAVE_PATH=./data/saved_models
ML_MONGO_URI=mongodb://localhost:27017/sentinelops
